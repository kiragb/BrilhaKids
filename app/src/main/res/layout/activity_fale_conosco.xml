<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFAE7">

    <!-- Conteúdo principal com ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFAE7"
            android:padding="24dp">

            <ImageView
                android:id="@+id/menuIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="40dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menu"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/logo"
                android:layout_width="wrap_content"
                android:layout_height="90dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Logo BrilhaKids"
                android:src="@drawable/logo_brilhakids"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toEndOf="@id/menuIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/fundo_laranja"
                android:layout_width="365dp"
                android:layout_height="634dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/fundo_laranja"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/logo">

                <TextView
                    android:id="@+id/tvBemVindo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/adigianaui"
                    android:text="Fale Conosco"
                    android:textColor="#085e9d"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.495"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                android:id="@+id/tvDescricao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/adigianaui"
                android:gravity="center"
                android:text="Tem alguma dúvida? Preencha o\nformulário abaixo e fale conosco :)"
                android:textColor="#444444"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.537"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvBemVindo" />

            <TextView
                android:id="@+id/tvConecte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conecte-se"
                android:textColor="#085e9d"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/adigianaui"
                app:layout_constraintTop_toBottomOf="@id/tvDescricao"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/Nome"
                android:layout_width="263dp"
                android:layout_height="wrap_content"
                android:hint="Nome"
                android:background="@drawable/bd_azulciano"
                android:padding="12dp"
                android:gravity="center"
                android:textColor="#000000"
                android:textColorHint="#FFFFFF"
                android:fontFamily="@font/adigianaui"
                app:layout_constraintTop_toBottomOf="@id/tvConecte"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"/>

            <EditText
                android:id="@+id/Email"
                android:layout_width="263dp"
                android:layout_height="wrap_content"
                android:hint="E-mail"
                android:background="@drawable/bd_azulciano"
                android:padding="12dp"
                android:gravity="center"
                android:textColor="#000000"
                android:textColorHint="#FFFFFF"
                android:fontFamily="@font/adigianaui"
                app:layout_constraintTop_toBottomOf="@id/Nome"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"/>

            <RadioGroup
                android:id="@+id/radioGroupSexo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/Email"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/telefone"
                android:layout_width="263dp"
                android:layout_height="50dp"
                android:hint="Telefone"
                android:background="@drawable/bd_azulciano"
                android:padding="12dp"
                android:gravity="center"
                android:textColor="#000000"
                android:textColorHint="#FFFFFF"
                android:fontFamily="@font/adigianaui"
                app:layout_constraintTop_toBottomOf="@id/radioGroupSexo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"/>

            <EditText
                android:id="@+id/comentario"
                android:layout_width="256dp"
                android:layout_height="120dp"
                android:hint="Comentário"
                android:inputType="textMultiLine"
                android:background="@drawable/bd_azulciano"
                android:padding="12dp"
                android:gravity="center"
                android:textColor="#000000"
                android:textColorHint="#FFFFFF"
                android:fontFamily="@font/adigianaui"
                app:layout_constraintTop_toBottomOf="@id/telefone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"/>

            <Button
                android:id="@+id/btnCadastrar"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:text="Enviar"
                android:backgroundTint="#085e9d"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="@font/adigianaui"
                app:layout_constraintTop_toBottomOf="@id/comentario"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="40dp"/>

                <ImageView
                    android:id="@+id/mensagem"
                    android:layout_width="53dp"
                    android:layout_height="42dp"
                    android:src="@drawable/mensagens"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/tvDescricao"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.097" />

                <ImageView
                    android:id="@+id/logofim"
                    android:layout_width="228dp"
                    android:layout_height="45dp"
                    android:contentDescription="Logo BrilhaKids"
                    android:src="@drawable/logo_brilhakids"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.496"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/btnCadastrar"
                    app:layout_constraintVertical_bias="0.686" />

            </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Menu lateral -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#2DA33E"
        app:itemIconSize="55dp"
        app:itemIconTint="@null"
        app:itemTextColor="@color/white"
        app:itemTextAppearance="@style/NavDrawerText"
        app:menu="@menu/menu_drawer_logged"
        app:headerLayout="@layout/nav_header"/>
</androidx.drawerlayout.widget.DrawerLayout>
