<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:background="@color/white"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:background="@drawable/fundo_laranja"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="700dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">
        <!-- Logo -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="188dp"
            android:layout_height="73dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/logo_brilhakids" />

        <!-- Texto de boas-vindas -->
        <TextView
            android:id="@+id/tvBemVindo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/adigianaui"
            android:text="Esqueci Minha Senha"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#055C9C"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvDescricaoemail"
            android:layout_width="275dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/adigianaui"
            android:gravity="center"
            android:text="Caso o e-mail já esteja cadastrado no BrilhaKids, você recebera uma mensagem com as instruções para definir uma nova senha"
            android:textColor="#444444"
            android:textSize="19sp" />

        <TextView
            android:id="@+id/tvDescricao"
            android:layout_width="275dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="--------------------"
            android:textColor="#085C9B"
            android:textSize="50sp" />

        <TextView
            android:id="@+id/tvDescricaonaoemail"
            android:layout_width="275dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/adigianaui"
            android:gravity="center"
            android:text="Caso não tenha recebido a mensagem vefifique se digitou o endereço e e-mail corretamente ou se caiu na caixa de spam"
            android:textColor="#837C6E"
            android:textSize="19sp" />

        <TextView
            android:id="@+id/tvReenviarEmail"
            android:layout_width="275dp"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/adigianaui"
            android:gravity="center"
            android:text="@string/label_sublinhado2"
            android:textColor="#37B6EB"
            android:textSize="16sp" />


    </LinearLayout>
</ScrollView>
