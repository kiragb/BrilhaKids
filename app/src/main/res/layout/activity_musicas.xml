<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFAE7">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="#FFFAE7">

            <ImageView
                android:id="@+id/menuIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="40dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menu"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/logo"
                android:layout_width="wrap_content"
                android:layout_height="90dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Logo BrilhaKids"
                android:src="@drawable/logo_brilhakids"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toEndOf="@id/menuIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/fundo_laranja"
                android:layout_width="365dp"
                android:layout_height="854dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/fundo_laranja"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/logo">

                <TextView
                    android:id="@+id/tvOlaUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/adigianaui"
                    android:text="Músicas Educativas"
                    android:textColor="#ab471a"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/carddino"
                    android:layout_width="148dp"
                    android:layout_height="144dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_azulclaro_arredondado"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvOlaUsuario" />

                <ImageView
                    android:id="@+id/imageamigo"
                    android:layout_width="94dp"
                    android:layout_height="70dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/textamigossauro"
                    app:layout_constraintEnd_toEndOf="@id/carddino"
                    app:layout_constraintStart_toStartOf="@id/carddino"
                    app:layout_constraintTop_toTopOf="@id/carddino" />

                <ImageView
                    android:id="@+id/imageamigodino"
                    android:layout_width="94dp"
                    android:layout_height="70dp"
                    android:layout_marginTop="68dp"
                    android:src="@drawable/dino"
                    app:layout_constraintEnd_toEndOf="@id/carddino"
                    app:layout_constraintStart_toStartOf="@id/carddino"
                    app:layout_constraintTop_toTopOf="@id/carddino" />

                <TextView
                    android:id="@+id/textamigo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/adigianaui"
                    android:text="Amigossauro"
                    android:textAlignment="center"
                    android:textColor="#085e9d"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@id/imageamigodino"
                    app:layout_constraintEnd_toEndOf="@id/carddino"
                    app:layout_constraintHorizontal_bias="0.484"
                    app:layout_constraintStart_toStartOf="@id/carddino"
                    app:layout_constraintTop_toTopOf="@id/carddino"
                    app:layout_constraintVertical_bias="0.173" />

                <ImageView
                    android:id="@+id/tartaruga"
                    android:layout_width="151dp"
                    android:layout_height="159dp"
                    android:layout_marginTop="16dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/music"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.06"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/carddino" />

                <ImageView
                    android:id="@+id/cardalfabeto"
                    android:layout_width="148dp"
                    android:layout_height="144dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_vermelho"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.073"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tartaruga" />


                <ImageView
                    android:id="@+id/imagealfabeto"
                    android:layout_width="106dp"
                    android:layout_height="63dp"
                    android:layout_marginTop="68dp"
                    android:src="@drawable/alfabeto"
                    app:layout_constraintEnd_toEndOf="@id/cardalfabeto"
                    app:layout_constraintHorizontal_bias="0.452"
                    app:layout_constraintStart_toStartOf="@id/cardalfabeto"
                    app:layout_constraintTop_toTopOf="@id/cardalfabeto" />

                <TextView
                    android:id="@+id/textalfabeto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/adigianaui"
                    android:text="Alfabeto da\nXuxa"
                    android:textAlignment="center"
                    android:textColor="#d80728"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@id/imagealfabeto"
                    app:layout_constraintEnd_toEndOf="@id/cardalfabeto"
                    app:layout_constraintHorizontal_bias="0.581"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/cardalfabeto"
                    app:layout_constraintVertical_bias="1.0" />

                
                <ImageView
                    android:id="@+id/cardmariana"
                    android:layout_width="148dp"
                    android:layout_height="144dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_rosa_arredondado"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.452"
                    app:layout_constraintStart_toEndOf="@+id/carddino"
                    app:layout_constraintTop_toBottomOf="@+id/tvOlaUsuario" />

                <ImageView
                    android:id="@+id/imagemariana"
                    android:layout_width="129dp"
                    android:layout_height="97dp"
                    android:src="@drawable/mariana"
                    app:layout_constraintBottom_toBottomOf="@id/cardmariana"
                    app:layout_constraintEnd_toEndOf="@id/cardmariana"
                    app:layout_constraintHorizontal_bias="0.452"
                    app:layout_constraintStart_toStartOf="@id/cardmariana"
                    app:layout_constraintTop_toTopOf="@id/cardmariana"
                    app:layout_constraintVertical_bias="0.839" />

                <TextView
                    android:id="@+id/textmariana"
                    android:layout_width="136dp"
                    android:layout_height="48dp"
                    android:fontFamily="@font/adigianaui"
                    android:text="Mariana"
                    android:textAlignment="center"
                    android:textColor="#e83853"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/cardmariana"
                    app:layout_constraintEnd_toEndOf="@id/cardmariana"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toStartOf="@id/cardmariana"
                    app:layout_constraintTop_toTopOf="@id/cardmariana"
                    app:layout_constraintVertical_bias="0.083" />

                <ImageView
                    android:id="@+id/planeta"
                    android:layout_width="158dp"
                    android:layout_height="162dp"
                    android:layout_marginTop="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/amigos"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.908"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cardcoleta" />

                <ImageView
                    android:id="@+id/cardcoleta"
                    android:layout_width="148dp"
                    android:layout_height="144dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="24dp"
                    android:background="@drawable/bg_amareloescuro"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.827"
                    app:layout_constraintStart_toEndOf="@+id/tartaruga"
                    app:layout_constraintTop_toBottomOf="@id/cardmariana" />

                <ImageView
                    android:id="@+id/imagecoleta"
                    android:layout_width="235dp"
                    android:layout_height="142dp"
                    android:layout_marginTop="32dp"
                    android:src="@drawable/turma"
                    app:layout_constraintEnd_toEndOf="@id/cardcoleta"
                    app:layout_constraintHorizontal_bias="0.471"
                    app:layout_constraintStart_toStartOf="@id/cardcoleta"
                    app:layout_constraintTop_toTopOf="@id/cardcoleta" />

                <TextView
                    android:id="@+id/textcoleta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/adigianaui"
                    android:text="Coleta\nSeletiva"
                    android:textAlignment="center"
                    android:textColor="#f78012"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/cardcoleta"
                    app:layout_constraintStart_toStartOf="@id/cardcoleta"
                    app:layout_constraintEnd_toEndOf="@id/cardcoleta"
                    app:layout_constraintTop_toTopOf="@id/cardcoleta"
                    app:layout_constraintVertical_bias="0.111" />

                <ImageView
                    android:id="@+id/xuxa"
                    android:layout_width="158dp"
                    android:layout_height="162dp"
                    android:layout_marginTop="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/cir"
                    app:layout_constraintEnd_toStartOf="@+id/cardchefe"
                    app:layout_constraintHorizontal_bias="0.516"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cardalfabeto" />

                <ImageView
                    android:id="@+id/cardchefe"
                    android:layout_width="148dp"
                    android:layout_height="144dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="28dp"
                    android:background="@drawable/bg_verdeescuro_arredondado"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/planeta" />

                <ImageView
                    android:id="@+id/imagechefe"
                    android:layout_width="106dp"
                    android:layout_height="63dp"
                    android:src="@drawable/esquerda"
                    app:layout_constraintBottom_toBottomOf="@+id/cardchefe"
                    app:layout_constraintEnd_toEndOf="@+id/cardchefe"
                    app:layout_constraintHorizontal_bias="0.476"
                    app:layout_constraintStart_toStartOf="@+id/cardchefe"
                    app:layout_constraintTop_toBottomOf="@+id/textchefe"
                    app:layout_constraintVertical_bias="0.45" />

                <TextView
                    android:id="@+id/textchefe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/adigianaui"
                    android:text="Chefinho\nMandou"
                    android:textAlignment="center"
                    android:textColor="#126816"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/cardchefe"
                    app:layout_constraintEnd_toEndOf="@+id/cardchefe"
                    app:layout_constraintHorizontal_bias="0.435"
                    app:layout_constraintStart_toStartOf="@+id/cardchefe"
                    app:layout_constraintTop_toTopOf="@+id/cardchefe"
                    app:layout_constraintVertical_bias="0.097" />

                <ImageView
                    android:id="@+id/logofim"
                    android:layout_width="228dp"
                    android:layout_height="45dp"
                    android:contentDescription="Logo BrilhaKids"
                    android:src="@drawable/logo_brilhakids"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.569"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tvOlaUsuario"
                    app:layout_constraintVertical_bias="0.979" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        app:itemIconSize="55dp"
        android:background="#2DA33E"
        app:itemTextColor="@color/white"
        app:itemTextAppearance="@style/NavDrawerText"
        app:itemIconTint="@null"
        android:layout_gravity="start"
        app:menu="@menu/menu_drawer_logged"
        app:headerLayout="@layout/nav_header" />

</androidx.drawerlayout.widget.DrawerLayout>