<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFAE7">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"> <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" android:background="#FFFAE7">

        <ImageView
            android:id="@+id/menuIcon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/ic_menu"
            android:contentDescription="Menu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/logo"
            android:layout_width="wrap_content"
            android:layout_height="90dp"
            android:layout_marginTop="16dp"
            android:contentDescription="Logo BrilhaKids"
            android:src="@drawable/logo_brilhakids"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toEndOf="@id/menuIcon"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/fundo_laranja"
            android:layout_width="365dp"
            android:layout_height="834dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/fundo_laranja"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logo">

            <TextView
                android:id="@+id/tvOlaUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/adigianaui"
                android:text="Jogos Manuais"
                android:textColor="#FF5722"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/cardJogos"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_azul_arredondado"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvOlaUsuario" />

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="121dp"
                android:layout_height="80dp"
                android:layout_marginTop="60dp"
                android:src="@drawable/quebra_cabeca"
                app:layout_constraintEnd_toEndOf="@id/cardJogos"
                app:layout_constraintStart_toStartOf="@id/cardJogos"
                app:layout_constraintTop_toTopOf="@id/cardJogos" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Quebra\nCabeça"
                android:textAlignment="center"
                android:textColor="#260066"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/imageView3"
                app:layout_constraintStart_toStartOf="@id/cardJogos"
                app:layout_constraintEnd_toEndOf="@id/cardJogos"
                app:layout_constraintTop_toTopOf="@id/cardJogos" />

            <ImageView
                android:id="@+id/cardLicoes"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rosa_arredondado"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.078"
                app:layout_constraintTop_toBottomOf="@id/cardJogos" />

            <ImageView
                android:id="@+id/imagelicoes"
                android:layout_width="128dp"
                android:layout_height="84dp"
                android:layout_marginTop="60dp"
                android:src="@drawable/alfabeto_divertido"
                app:layout_constraintEnd_toEndOf="@id/cardLicoes"
                app:layout_constraintStart_toStartOf="@id/cardLicoes"
                app:layout_constraintTop_toTopOf="@id/cardLicoes" />

            <TextView
                android:id="@+id/textalfabeto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Alfabeto\nDivertido"
                android:textAlignment="center"
                android:textColor="#B30000"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/imagelicoes"
                app:layout_constraintStart_toStartOf="@id/cardLicoes"
                app:layout_constraintEnd_toEndOf="@id/cardLicoes"
                app:layout_constraintTop_toTopOf="@id/cardLicoes" />

            <ImageView
                android:id="@+id/cardEmocoes"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_amarelo_arredondado"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.889"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvOlaUsuario" />

            <ImageView
                android:id="@+id/imagemusic"
                android:layout_width="111dp"
                android:layout_height="72dp"
                android:src="@drawable/jogo_emocoes"
                app:layout_constraintBottom_toBottomOf="@id/cardEmocoes"
                app:layout_constraintEnd_toEndOf="@id/cardEmocoes"
                app:layout_constraintStart_toStartOf="@id/cardEmocoes"
                app:layout_constraintTop_toTopOf="@id/cardEmocoes"
                app:layout_constraintVertical_bias="0.836" />

            <TextView
                android:id="@+id/TextMusic"
                android:layout_width="97dp"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/adigianaui"
                android:text="Jogo das\nEmoções"
                android:textAlignment="center"
                android:textColor="#663300"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/cardEmocoes"
                app:layout_constraintHorizontal_bias="0.47"
                app:layout_constraintStart_toStartOf="@id/cardEmocoes"
                app:layout_constraintTop_toTopOf="@id/cardEmocoes"
                app:layout_constraintVertical_bias="0.1" />

            <ImageView
                android:id="@+id/cardJogosManuais"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_verde_arredondado"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardEmocoes" />

            <ImageView
                android:id="@+id/carddicas"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="296dp"
                android:background="@drawable/bg_roxo_arredondado"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardJogosManuais"
                app:layout_constraintVertical_bias="1.0" />

            <ImageView
                android:id="@+id/carddicas2"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="136dp"
                android:background="@drawable/bg_verdeescuro_arredondado"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/carddicas"
                app:layout_constraintVertical_bias="1.0" />

            <ImageView
                android:id="@+id/cardfale"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginEnd="200dp"
                android:background="@drawable/bg_azulclaro_arredondado"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardJogosManuais"
                app:layout_constraintVertical_bias="0.054" />

            <ImageView
                android:id="@+id/cardfale2"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginEnd="200dp"
                android:background="@drawable/bg_amareloescuro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardLicoes"
                app:layout_constraintVertical_bias="0.054" />

            <ImageView
                android:id="@+id/cardfale3"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginEnd="200dp"
                android:background="@drawable/bg_azulclaro_arredondado"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardfale"
                app:layout_constraintVertical_bias="0.105" />

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="114dp"
                android:layout_height="83dp"
                android:layout_marginTop="56dp"
                android:src="@drawable/antecessores"
                app:layout_constraintEnd_toEndOf="@id/cardJogosManuais"
                app:layout_constraintHorizontal_bias="0.558"
                app:layout_constraintStart_toStartOf="@id/cardJogosManuais"
                app:layout_constraintTop_toTopOf="@id/cardJogosManuais" />

            <ImageView
                android:id="@+id/imageView5"
                android:layout_width="129dp"
                android:layout_height="93dp"
                android:src="@drawable/jogo_das_silabas"
                app:layout_constraintBottom_toBottomOf="@+id/cardfale"
                app:layout_constraintEnd_toEndOf="@id/cardfale"
                app:layout_constraintHorizontal_bias="0.473"
                app:layout_constraintStart_toStartOf="@id/cardfale"
                app:layout_constraintTop_toTopOf="@id/cardfale"
                app:layout_constraintVertical_bias="1.0" />

            <ImageView
                android:id="@+id/imageView7"
                android:layout_width="126dp"
                android:layout_height="89dp"
                android:src="@drawable/decisoes"
                app:layout_constraintBottom_toBottomOf="@+id/cardfale3"
                app:layout_constraintEnd_toEndOf="@+id/cardfale3"
                app:layout_constraintHorizontal_bias="0.454"
                app:layout_constraintStart_toStartOf="@+id/cardfale3"
                app:layout_constraintTop_toTopOf="@+id/cardfale3"
                app:layout_constraintVertical_bias="1.0" />

            <ImageView
                android:id="@+id/imageView9"
                android:layout_width="117dp"
                android:layout_height="75dp"
                android:src="@drawable/caixa"
                app:layout_constraintBottom_toBottomOf="@+id/carddicas2"
                app:layout_constraintEnd_toEndOf="@+id/carddicas2"
                app:layout_constraintHorizontal_bias="0.482"
                app:layout_constraintStart_toStartOf="@+id/carddicas2"
                app:layout_constraintTop_toTopOf="@+id/textView6"
                app:layout_constraintVertical_bias="0.86" />

            <ImageView
                android:id="@+id/imageView6"
                android:layout_width="110dp"
                android:layout_height="88dp"
                android:layout_marginBottom="4dp"
                android:src="@drawable/jogo_da_velha"
                app:layout_constraintBottom_toBottomOf="@+id/carddicas"
                app:layout_constraintEnd_toEndOf="@id/carddicas"
                app:layout_constraintStart_toStartOf="@id/carddicas"
                app:layout_constraintHorizontal_bias="0.50"
                />

            <ImageView
                android:id="@+id/imageView8"
                android:layout_width="97dp"
                android:layout_height="75dp"
                android:src="@drawable/jogo_da_velha"
                app:layout_constraintBottom_toBottomOf="@+id/carddicas"
                app:layout_constraintEnd_toEndOf="@+id/carddicas2"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@+id/carddicas2"
                app:layout_constraintTop_toBottomOf="@+id/textView6"
                app:layout_constraintVertical_bias="1.0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Antecessores e\nSucessores"
                android:textAlignment="center"
                android:textColor="#005000"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/cardJogosManuais"
                app:layout_constraintStart_toStartOf="@id/cardJogosManuais"
                app:layout_constraintEnd_toEndOf="@id/cardJogosManuais"
                app:layout_constraintTop_toTopOf="@id/cardJogosManuais"
                app:layout_constraintVertical_bias="0.111" />

            <TextView
                android:id="@+id/TextView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Jogo da\nVelha"
                android:textAlignment="center"
                android:textColor="#2e0084"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/carddicas"
                app:layout_constraintEnd_toEndOf="@+id/carddicas"
                app:layout_constraintHorizontal_bias="0.493"
                app:layout_constraintStart_toStartOf="@+id/carddicas"
                app:layout_constraintTop_toTopOf="@+id/carddicas"
                app:layout_constraintVertical_bias="0.0" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Caixa\nCuriosa"
                android:textAlignment="center"
                android:textColor="#45a102"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/carddicas2"
                app:layout_constraintEnd_toEndOf="@+id/carddicas2"
                app:layout_constraintHorizontal_bias="0.52"
                app:layout_constraintStart_toStartOf="@+id/carddicas2"
                app:layout_constraintTop_toTopOf="@+id/carddicas2"
                app:layout_constraintVertical_bias="0.101" />

            <TextView
                android:id="@+id/TextView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Jogo das\nSílabas"
                android:textAlignment="center"
                android:textColor="#f78012"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/cardfale"
                app:layout_constraintEnd_toEndOf="@+id/cardfale"
                app:layout_constraintHorizontal_bias="0.523"
                app:layout_constraintStart_toStartOf="@+id/cardfale"
                app:layout_constraintTop_toTopOf="@+id/cardfale"
                app:layout_constraintVertical_bias="0.076" />

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Jogo fas\nDecisões"
                android:textAlignment="center"
                android:textColor="#085e9d"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/cardfale3"
                app:layout_constraintEnd_toEndOf="@+id/cardfale3"
                app:layout_constraintHorizontal_bias="0.48"
                app:layout_constraintStart_toStartOf="@+id/cardfale3"
                app:layout_constraintTop_toTopOf="@+id/cardfale3"
                app:layout_constraintVertical_bias="0.101" />

            <ImageView
                android:id="@+id/logofim"
                android:layout_width="228dp"
                android:layout_height="45dp"
                android:contentDescription="Logo BrilhaKids"
                android:src="@drawable/logo_brilhakids"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.569"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tvOlaUsuario"
                app:layout_constraintVertical_bias="0.979" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        app:itemIconSize="55dp"
        android:background="#2DA33E"
        app:itemTextColor="@color/white"
        app:itemTextAppearance="@style/NavDrawerText"
        app:itemIconTint="@null"
        android:layout_gravity="start"
        app:menu="@menu/menu_drawer_logged"
        app:headerLayout="@layout/nav_header" />

</androidx.drawerlayout.widget.DrawerLayout>