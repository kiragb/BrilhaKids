<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFAE7">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" android:background="#FFFAE7">

        <ImageView
            android:id="@+id/menuIcon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/ic_menu"
            android:contentDescription="Menu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/logo"
            android:layout_width="wrap_content"
            android:layout_height="90dp"
            android:layout_marginTop="16dp"
            android:contentDescription="Logo BrilhaKids"
            android:src="@drawable/logo_brilhakids"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toEndOf="@id/menuIcon"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/fundo_laranja"
            android:layout_width="365dp"
            android:layout_height="654dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/fundo_laranja"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logo">

            <TextView
                android:id="@+id/tvOlaUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/adigianaui"
                android:text="Vídeos Educativos"
                android:textColor="#2e0084"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/cardacoes"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_azulclaro_arredondado"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvOlaUsuario" />

            <ImageView
                android:id="@+id/imagacoes"
                android:layout_width="94dp"
                android:layout_height="70dp"
                android:layout_marginTop="60dp"
                android:src="@drawable/escovar"
                app:layout_constraintStart_toStartOf="@id/cardacoes"
                app:layout_constraintEnd_toEndOf="@id/cardacoes"
                app:layout_constraintTop_toTopOf="@id/cardacoes" />

            <TextView
                android:id="@+id/textacoes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Ações\nCotidianas"
                android:textAlignment="center"
                android:textColor="#085e9d"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/imagacoes"
                app:layout_constraintStart_toStartOf="@id/cardacoes"
                app:layout_constraintEnd_toEndOf="@id/cardacoes"
                app:layout_constraintTop_toTopOf="@id/cardacoes" />

            <ImageView
                android:id="@+id/tartaruga"
                android:layout_width="151dp"
                android:layout_height="159dp"
                android:layout_marginTop="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/tartaruga"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.06"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardacoes" />

            <ImageView
                android:id="@+id/cardmatematica"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_rosaclaro"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.073"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tartaruga" />

            <ImageView
                android:id="@+id/imagematematica"
                android:layout_width="121dp"
                android:layout_height="82dp"
                android:layout_marginTop="52dp"
                android:src="@drawable/matematica"
                app:layout_constraintEnd_toEndOf="@id/cardmatematica"
                app:layout_constraintHorizontal_bias="0.37"
                app:layout_constraintStart_toStartOf="@id/cardmatematica"
                app:layout_constraintTop_toTopOf="@id/cardmatematica" />

            <TextView
                android:id="@+id/textmatematica"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Matemática"
                android:textAlignment="center"
                android:textColor="#e83853"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/imagematematica"
                app:layout_constraintStart_toStartOf="@id/cardmatematica"
                app:layout_constraintEnd_toEndOf="@id/cardmatematica"
                app:layout_constraintTop_toTopOf="@id/cardmatematica" />

            <ImageView
                android:id="@+id/cardpreservar"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_verdeescuro_arredondado"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.452"
                app:layout_constraintStart_toEndOf="@+id/cardacoes"
                app:layout_constraintTop_toBottomOf="@+id/tvOlaUsuario" />

            <ImageView
                android:id="@+id/imagepreservar"
                android:layout_width="95dp"
                android:layout_height="63dp"
                android:src="@drawable/lixeira"
                app:layout_constraintBottom_toBottomOf="@id/cardpreservar"
                app:layout_constraintEnd_toEndOf="@id/cardpreservar"
                app:layout_constraintStart_toStartOf="@id/cardpreservar"
                app:layout_constraintTop_toTopOf="@id/cardpreservar"
                app:layout_constraintVertical_bias="0.836" />

            <TextView
                android:id="@+id/textpreservar"
                android:layout_width="136dp"
                android:layout_height="48dp"
                android:fontFamily="@font/adigianaui"
                android:text="Preservando a\nNatureza"
                android:textAlignment="center"
                android:textColor="#45a102"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/cardpreservar"
                app:layout_constraintEnd_toEndOf="@id/cardpreservar"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@id/cardpreservar"
                app:layout_constraintTop_toTopOf="@id/cardpreservar"
                app:layout_constraintVertical_bias="0.083" />

            <ImageView
                android:id="@+id/planeta"
                android:layout_width="158dp"
                android:layout_height="162dp"
                android:layout_marginTop="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/planeta"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.908"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardvocabulario" />

            <ImageView
                android:id="@+id/cardvocabulario"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_amareloescuro"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.827"
                app:layout_constraintStart_toEndOf="@+id/tartaruga"
                app:layout_constraintTop_toBottomOf="@id/cardpreservar" />

            <ImageView
                android:id="@+id/imagevocabulario"
                android:layout_width="100dp"
                android:layout_height="84dp"
                android:layout_marginTop="48dp"
                android:src="@drawable/animais"
                app:layout_constraintStart_toStartOf="@id/cardvocabulario"
                app:layout_constraintEnd_toEndOf="@id/cardvocabulario"
                app:layout_constraintTop_toTopOf="@id/cardvocabulario" />

            <TextView
                android:id="@+id/textvocabulario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Vocabulário"
                android:textAlignment="center"
                android:textColor="#f78012"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/cardvocabulario"
                app:layout_constraintStart_toStartOf="@id/cardvocabulario"
                app:layout_constraintEnd_toEndOf="@id/cardvocabulario"
                app:layout_constraintTop_toTopOf="@id/cardvocabulario"
                app:layout_constraintVertical_bias="0.111" />

            <ImageView
                android:id="@+id/logofim"
                android:layout_width="228dp"
                android:layout_height="45dp"
                android:contentDescription="Logo BrilhaKids"
                android:src="@drawable/logo_brilhakids"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.569"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tvOlaUsuario"
                app:layout_constraintVertical_bias="0.979" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        app:itemIconSize="55dp"
        android:background="#2DA33E"
        app:itemTextColor="@color/white"
        app:itemTextAppearance="@style/NavDrawerText"
        app:itemIconTint="@null"
        android:layout_gravity="start"
        app:menu="@menu/menu_drawer_logged"
        app:headerLayout="@layout/nav_header" />

</androidx.drawerlayout.widget.DrawerLayout>