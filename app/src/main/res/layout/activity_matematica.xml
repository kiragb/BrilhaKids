<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFAE7">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="#FFFAE7">

            <ImageView
                android:id="@+id/menuIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="40dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menu"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/logo"
                android:layout_width="wrap_content"
                android:layout_height="90dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Logo BrilhaKids"
                android:src="@drawable/logo_brilhakids"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toEndOf="@id/menuIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/fundo_laranja"
                android:layout_width="365dp"
                android:layout_height="654dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/fundo_laranja"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/logo">

                <TextView
                    android:id="@+id/tvOlaUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/adigianaui"
                    android:text="Matemática"
                    android:textColor="#78068A"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/cardformas"
                    android:layout_width="317dp"
                    android:layout_height="148dp"
                    android:layout_marginStart="28dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_verdeescuro_arredondado"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvOlaUsuario" />

                <ImageView
                    android:id="@+id/imagepocoyo"
                    android:layout_width="122dp"
                    android:layout_height="103dp"
                    android:layout_marginTop="44dp"
                    android:src="@drawable/pocoyo"
                    app:layout_constraintEnd_toEndOf="@id/cardformas"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="@id/cardformas"
                    app:layout_constraintTop_toTopOf="@id/cardformas" />

                <ImageView
                    android:id="@+id/imagebloco"
                    android:layout_width="161dp"
                    android:layout_height="124dp"
                    android:layout_marginTop="40dp"
                    android:src="@drawable/blocos"
                    app:layout_constraintEnd_toEndOf="@id/cardformas"
                    app:layout_constraintHorizontal_bias="0.264"
                    app:layout_constraintStart_toEndOf="@+id/imagepocoyo"
                    app:layout_constraintTop_toTopOf="@id/cardformas" />

                <TextView
                    android:id="@+id/textformas"
                    android:layout_width="247dp"
                    android:layout_height="51dp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/adigianaui"
                    android:text="Formas Geométricas\ncom Pocoyo"
                    android:textAlignment="center"
                    android:textColor="#356D0B"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="@id/cardformas"
                    app:layout_constraintHorizontal_bias="0.54"
                    app:layout_constraintStart_toStartOf="@id/cardformas"
                    app:layout_constraintTop_toTopOf="@id/cardformas" />

                <ImageView
                    android:id="@+id/girafa"
                    android:layout_width="151dp"
                    android:layout_height="159dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="24dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/opera"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cardformas" />

                <ImageView
                    android:id="@+id/cardnumeros"
                    android:layout_width="317dp"
                    android:layout_height="148dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_azulbemclaro"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/girafa" />

                <ImageView
                    android:id="@+id/imagenumeros"
                    android:layout_width="176dp"
                    android:layout_height="75dp"
                    android:layout_marginTop="48dp"
                    android:src="@drawable/umacem"
                    app:layout_constraintEnd_toEndOf="@id/cardnumeros"
                    app:layout_constraintHorizontal_bias="0.496"
                    app:layout_constraintStart_toStartOf="@id/cardnumeros"
                    app:layout_constraintTop_toTopOf="@id/cardnumeros" />

                <TextView
                    android:id="@+id/textnumeros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/adigianaui"
                    android:text="Cançao dos Números"
                    android:textAlignment="center"
                    android:textColor="#085e9d"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@id/imagenumeros"
                    app:layout_constraintStart_toStartOf="@id/cardnumeros"
                    app:layout_constraintEnd_toEndOf="@id/cardnumeros"
                    app:layout_constraintTop_toTopOf="@id/cardnumeros" />

                <ImageView
                    android:id="@+id/cardquarto"
                    android:layout_width="148dp"
                    android:layout_height="144dp"
                    android:background="@drawable/bg_branco"
                    app:layout_constraintBottom_toTopOf="@+id/cardnumeros"
                    app:layout_constraintEnd_toStartOf="@+id/girafa"
                    app:layout_constraintHorizontal_bias="0.666"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cardformas"
                    app:layout_constraintVertical_bias="0.612" />

                <ImageView
                    android:id="@+id/imagequarto"
                    android:layout_width="119dp"
                    android:layout_height="92dp"
                    android:layout_marginTop="56dp"
                    android:src="@drawable/kento"
                    app:layout_constraintEnd_toEndOf="@id/cardquarto"
                    app:layout_constraintHorizontal_bias="0.413"
                    app:layout_constraintStart_toStartOf="@id/cardquarto"
                    app:layout_constraintTop_toTopOf="@id/cardquarto" />

                <TextView
                    android:id="@+id/textquarto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/adigianaui"
                    android:text="Arrumando o\nQuarto"
                    android:textAlignment="center"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/cardquarto"
                    app:layout_constraintEnd_toEndOf="@id/cardquarto"
                    app:layout_constraintHorizontal_bias="0.48"
                    app:layout_constraintStart_toStartOf="@id/cardquarto"
                    app:layout_constraintTop_toTopOf="@id/cardquarto"
                    app:layout_constraintVertical_bias="0.086" />

                <ImageView
                    android:id="@+id/logofim"
                    android:layout_width="228dp"
                    android:layout_height="45dp"
                    android:contentDescription="Logo BrilhaKids"
                    android:src="@drawable/logo_brilhakids"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.569"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tvOlaUsuario"
                    app:layout_constraintVertical_bias="0.979" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        app:itemIconSize="55dp"
        android:background="#2DA33E"
        app:itemTextColor="@color/white"
        app:itemTextAppearance="@style/NavDrawerText"
        app:itemIconTint="@null"
        android:layout_gravity="start"
        app:menu="@menu/menu_drawer_logged"
        app:headerLayout="@layout/nav_header" />

</androidx.drawerlayout.widget.DrawerLayout>