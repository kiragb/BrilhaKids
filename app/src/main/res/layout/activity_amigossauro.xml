<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFAE7">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="#FFFAE7">

            <ImageView
                android:id="@+id/menuIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="40dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menu"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/logo"
                android:layout_width="wrap_content"
                android:layout_height="90dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Logo BrilhaKids"
                android:src="@drawable/logo_brilhakids"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toEndOf="@id/menuIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/fundo_laranja"
                android:layout_width="365dp"
                android:layout_height="614dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/fundo_laranja"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/logo">


                <ImageView
                    android:id="@+id/cardJogos"
                    android:layout_width="303dp"
                    android:layout_height="502dp"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_bordaazul"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/textacoes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:fontFamily="@font/adigianaui"
                    android:text="Amigossauro\nAmarrar o sapato"
                    android:textAlignment="center"
                    android:textColor="#009688"
                    android:textSize="27sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="@id/cardJogos"
                    app:layout_constraintHorizontal_bias="0.492"
                    app:layout_constraintStart_toStartOf="@id/cardJogos"
                    app:layout_constraintTop_toTopOf="@id/cardJogos" />

                <androidx.media3.ui.PlayerView
                    android:id="@+id/playerView"
                    android:layout_width="264dp"
                    android:layout_height="206dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="16dp"
                    app:auto_show="true"
                    app:controller_layout_id="@layout/exo_player_control_view"
                    app:hide_on_touch="true"
                    app:layout_constraintBottom_toTopOf="@+id/descr"
                    app:layout_constraintDimensionRatio="16:9"
                    app:layout_constraintEnd_toEndOf="@id/cardJogos"
                    app:layout_constraintStart_toStartOf="@id/cardJogos"
                    app:layout_constraintTop_toBottomOf="@id/textacoes"
                    app:layout_constraintVertical_bias="0.319"
                    app:resize_mode="fit"
                    app:show_timeout="5000"
                    app:surface_type="surface_view"
                    app:use_controller="true" />

                <ImageView
                    android:id="@+id/logofim"
                    android:layout_width="228dp"
                    android:layout_height="45dp"
                    android:layout_marginBottom="4dp"
                    android:contentDescription="Logo BrilhaKids"
                    android:src="@drawable/logo_brilhakids"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.532"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/descr"
                    android:layout_width="238dp"
                    android:layout_height="134dp"
                    android:layout_marginBottom="32dp"
                    android:fontFamily="@font/adigianaui"
                    android:justificationMode="inter_word"
                    android:text="Aprenda a amarrar o sapato com o amigossauro e sua turma."
                    android:textColor="#009688"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/cardJogos"
                    app:layout_constraintEnd_toEndOf="@+id/cardJogos"
                    app:layout_constraintHorizontal_bias="0.514"
                    app:layout_constraintStart_toStartOf="@+id/cardJogos" />

                <ImageView
                    android:id="@+id/pasta"
                    android:layout_width="87dp"
                    android:layout_height="61dp"
                    android:src="@drawable/dino"
                    app:layout_constraintBottom_toBottomOf="@+id/cardJogos"
                    app:layout_constraintEnd_toEndOf="@+id/cardJogos"
                    app:layout_constraintHorizontal_bias="0.537"
                    app:layout_constraintStart_toStartOf="@+id/cardJogos"
                    app:layout_constraintTop_toTopOf="@+id/descr"
                    app:layout_constraintVertical_bias="0.828" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        app:itemIconSize="55dp"
        android:background="#2DA33E"
        app:itemTextColor="@color/white"
        app:itemTextAppearance="@style/NavDrawerText"
        app:itemIconTint="@null"
        android:layout_gravity="start"
        app:menu="@menu/menu_drawer_logged"
        app:headerLayout="@layout/nav_header" />

</androidx.drawerlayout.widget.DrawerLayout>