            android:layout_width="365dp"
            android:layout_height="994dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/fundo_laranja"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logo">

            <TextView
                android:id="@+id/tvOlaUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/adigianaui"
                android:text="Dicas"
                android:textColor="#E91E63"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/cardJogos"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_azul_arredondado"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvOlaUsuario" />

            <TextView
                android:id="@+id/texdescri1"
                android:layout_width="127dp"
                android:layout_height="67dp"
                android:layout_marginTop="60dp"
                android:fontFamily="@font/adigianaui"
                android:text="Entenda e compreenda o transtorno"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/cardJogos"
                app:layout_constraintStart_toStartOf="@id/cardJogos"
                app:layout_constraintTop_toTopOf="@id/cardJogos" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Dica 1"
                android:textAlignment="center"
                android:textColor="#260066"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/texdescri1"
                app:layout_constraintStart_toStartOf="@id/cardJogos"
                app:layout_constraintEnd_toEndOf="@id/cardJogos"
                app:layout_constraintTop_toTopOf="@id/cardJogos" />

            <ImageView
                android:id="@+id/menina"
                android:layout_width="187dp"
                android:layout_height="200dp"
                android:layout_marginTop="28dp"
                android:scaleType="fitCenter"
                android:src="@drawable/mae"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.937"
                app:layout_constraintTop_toBottomOf="@id/tvOlaUsuario" />

            <ImageView
                android:id="@+id/cardLicoes"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rosa_arredondado"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.078"
                app:layout_constraintTop_toBottomOf="@id/cardJogos" />

            <TextView
                android:id="@+id/textdescri2"
                android:layout_width="121dp"
                android:layout_height="82dp"
                android:layout_marginTop="52dp"
                android:fontFamily="@font/adigianaui"
                android:text="Não se importe com a opnião alheia"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/cardLicoes"
                app:layout_constraintHorizontal_bias="0.333"
                app:layout_constraintStart_toStartOf="@id/cardLicoes"
                app:layout_constraintTop_toTopOf="@id/cardLicoes" />

            <TextView
                android:id="@+id/textlicoes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Dica 2"
                android:textAlignment="center"
                android:textColor="#B30000"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/textdescri2"
                app:layout_constraintStart_toStartOf="@id/cardLicoes"
                app:layout_constraintEnd_toEndOf="@id/cardLicoes"
                app:layout_constraintTop_toTopOf="@id/cardLicoes" />

            <ImageView
                android:id="@+id/cardMusicas"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginTop="212dp"
                android:background="@drawable/bg_amarelo_arredondado"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.925"
                app:layout_constraintTop_toTopOf="@id/menina" />

            <TextView
                android:id="@+id/textdescri3"
                android:layout_width="120dp"
                android:layout_height="89dp"
                android:fontFamily="@font/adigianaui"
                android:text="Você pode e deve pedir ajuda"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"                app:layout_constraintStart_toStartOf="@id/cardMusicas"
                app:layout_constraintEnd_toEndOf="@id/cardMusicas"
                app:layout_constraintTop_toTopOf="@id/cardMusicas"
                app:layout_constraintBottom_toBottomOf="@id/cardMusicas"
                app:layout_constraintVertical_bias="0.836" />

            <TextView
                android:id="@+id/TextMusic"
                android:layout_width="84dp"
                android:layout_height="26dp"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/adigianaui"
                android:text="Dica 3"
                android:textAlignment="center"
                android:textColor="#663300"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/cardMusicas"
                app:layout_constraintEnd_toEndOf="@id/cardMusicas"
                app:layout_constraintTop_toTopOf="@id/cardMusicas"
                app:layout_constraintVertical_bias="0.1" />

            <ImageView
                android:id="@+id/menino"
                android:layout_width="187dp"
                android:layout_height="200dp"
                android:layout_marginStart="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/cerebro"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardLicoes" />

            <ImageView
                android:id="@+id/cardJogosManuais"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_verde_arredondado"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.915"
                app:layout_constraintStart_toStartOf="@id/menino"
                app:layout_constraintTop_toBottomOf="@id/cardMusicas" />

            <ImageView
                android:id="@+id/carddicas"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:background="@drawable/bg_roxo_arredondado"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.019"
                app:layout_constraintStart_toStartOf="@id/menino"
                app:layout_constraintTop_toBottomOf="@+id/menino"
                app:layout_constraintVertical_bias="0.058" />

            <ImageView
                android:id="@+id/cardfale"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:background="@drawable/bg_azulclaro_arredondado"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.915"
                app:layout_constraintStart_toStartOf="@id/menino"
                app:layout_constraintTop_toBottomOf="@+id/cardJogosManuais"
                app:layout_constraintVertical_bias="0.053" />

            <TextView
                android:id="@+id/textdescri4"
                android:layout_width="100dp"
                android:layout_height="84dp"
                android:layout_marginTop="48dp"
                android:fontFamily="@font/adigianaui"
                android:text="Arrume um tempo para você"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/cardJogosManuais"
                app:layout_constraintEnd_toEndOf="@id/cardJogosManuais"
                app:layout_constraintTop_toTopOf="@id/cardJogosManuais" />

            <TextView
                android:id="@+id/textdescri6"
                android:layout_width="100dp"
                android:layout_height="84dp"
                android:fontFamily="@font/adigianaui"
                android:text="Busque o tratamento adequado"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/cardfale"
                app:layout_constraintEnd_toEndOf="@id/cardfale"
                app:layout_constraintStart_toStartOf="@id/cardfale"
                app:layout_constraintTop_toTopOf="@id/cardfale"
                app:layout_constraintVertical_bias="0.766" />

            <TextView
                android:id="@+id/textdescri5"
                android:layout_width="100dp"
                android:layout_height="84dp"
                android:fontFamily="@font/adigianaui"
                android:text="Ajude sua criança"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/carddicas"
                app:layout_constraintEnd_toEndOf="@id/carddicas"
                app:layout_constraintHorizontal_bias="0.437"
                app:layout_constraintStart_toStartOf="@id/carddicas"
                app:layout_constraintTop_toTopOf="@id/carddicas"
                app:layout_constraintVertical_bias="0.766" />

            <TextView
                android:id="@+id/textjogosmanuais"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Dica 4"
                android:textAlignment="center"
                android:textColor="#005000"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/cardJogosManuais"
                app:layout_constraintStart_toStartOf="@id/cardJogosManuais"
                app:layout_constraintEnd_toEndOf="@id/cardJogosManuais"
                app:layout_constraintTop_toTopOf="@id/cardJogosManuais"
                app:layout_constraintVertical_bias="0.111" />

            <TextView
                android:id="@+id/TextView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Dica 5"
                android:textAlignment="center"
                android:textColor="#2e0084"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/carddicas"
                app:layout_constraintEnd_toEndOf="@+id/carddicas"
                app:layout_constraintHorizontal_bias="0.52"
                app:layout_constraintStart_toStartOf="@+id/carddicas"
                app:layout_constraintTop_toTopOf="@+id/carddicas"
                app:layout_constraintVertical_bias="0.076" />

            <TextView
                android:id="@+id/TextView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Dica 6"
                android:textAlignment="center"
                android:textColor="#085e9d"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/cardfale"
                app:layout_constraintEnd_toEndOf="@+id/cardfale"
                app:layout_constraintStart_toStartOf="@+id/cardfale"
                app:layout_constraintTop_toTopOf="@+id/cardfale"
                app:layout_constraintVertical_bias="0.118" />

            <ImageView
                android:id="@+id/logofim"
                android:layout_width="228dp"
                android:layout_height="45dp"
                android:contentDescription="Logo BrilhaKids"
                android:src="@drawable/logo_brilhakids"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.569"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tvOlaUsuario"
                app:layout_constraintVertical_bias="0.979" />


            <ImageView
                android:id="@+id/carddica2"
                android:layout_width="148dp"
                android:layout_height="144dp"
                android:background="@drawable/bg_amareloescuro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.087"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/carddicas"
                app:layout_constraintVertical_bias="0.151" />

            <TextView
                android:id="@+id/TextView7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adigianaui"
                android:text="Dica 7"
                android:textAlignment="center"
                android:textColor="#f78012"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/textdescri7"
                app:layout_constraintEnd_toEndOf="@+id/carddica2"
                app:layout_constraintHorizontal_bias="0.495"
                app:layout_constraintStart_toStartOf="@+id/carddicas"
                app:layout_constraintTop_toTopOf="@+id/carddica2"
                app:layout_constraintVertical_bias="0.454" />

            <TextView
                android:id="@+id/textdescri7"
                android:layout_width="110dp"
                android:layout_height="75dp"
                android:fontFamily="@font/adigianaui"
                android:text="Tenha uma boa comunicação"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/carddica2"
                app:layout_constraintEnd_toEndOf="@+id/carddica2"
                app:layout_constraintStart_toStartOf="@+id/carddica2"
                app:layout_constraintTop_toTopOf="@+id/carddica2"
                app:layout_constraintVertical_bias="0.695" />

            <ImageView
                android:id="@+id/tea"
                android:layout_width="176dp"
                android:layout_height="177dp"
                android:scaleType="fitCenter"
                android:src="@drawable/tea"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.272"
                app:layout_constraintStart_toEndOf="@+id/carddica2"
                app:layout_constraintTop_toBottomOf="@+id/cardfale"
                app:layout_constraintVertical_bias="0.015" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        app:itemIconSize="55dp"
        android:background="#2DA33E"
        app:itemTextColor="@color/white"
        app:itemTextAppearance="@style/NavDrawerText"
        app:itemIconTint="@null"
        android:layout_gravity="start"
        app:menu="@menu/menu_drawer_logged"
        app:headerLayout="@layout/nav_header" />

</androidx.drawerlayout.widget.DrawerLayout>